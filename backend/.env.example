# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=sigi_db
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword

# Authentication/JWT
JWT_SECRET_KEY=super-secret-key-change-in-production

# App Configurations
FLASK_ENV=development
DEBUG=True

# Allow CORS
CORS_ORIGINS=*

# Pagination Rules
DEFAULT_PER_PAGE=20
MAX_PER_PAGE=100
